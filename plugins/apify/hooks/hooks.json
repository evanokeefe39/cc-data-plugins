{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ToolSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-all-apify-mcp.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-all-apify-mcp.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/approve-plugin-reads.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
