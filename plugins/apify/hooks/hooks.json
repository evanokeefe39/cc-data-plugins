{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ToolSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/redirect-to-skill.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "apify",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-direct-mcp.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
